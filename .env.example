# =============================================================================
# verion-ai-grader — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# ---------------------------------------------------------------------------
# Django core (REQUIRED)
# ---------------------------------------------------------------------------

# Generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to True for local development only
DEBUG=False

# Comma-separated list of allowed hostnames (leave empty to use DEBUG default)
# ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database — shared (REQUIRED)
# ---------------------------------------------------------------------------

# Shared PostgreSQL database — same instance used by the main Next.js system.
# The grader app (grader_gradingresult, grader_answerfeedback) and all
# managed=False read-only models live here.
# Use sslmode=require for Neon (verify-full requires a local root cert).
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ---------------------------------------------------------------------------
# Database — Django system (OPTIONAL)
# ---------------------------------------------------------------------------

# Connection string for Django's own system tables:
#   auth_*, django_content_type, django_migrations, auth_keys_apikey
#
# If not set, defaults to a local SQLite file (django_system.db) — fine for
# development and single-server deployments.
#
# Set this to a separate Postgres database or schema in production so that
# Django's tables never appear in the shared database and never cause Prisma
# drift detection errors.
#
# DJANGO_DB_URL=postgresql://user:password@host:5432/django_system?sslmode=require

# ---------------------------------------------------------------------------
# AI grading client — choose ONE provider
# ---------------------------------------------------------------------------

# AI_PROVIDER = bedrock | ollama | gemini   (default: bedrock)
# Only the chosen provider's settings are required.
AI_PROVIDER=gemini

# --- Gemini (REQUIRED if AI_PROVIDER=gemini) ---
# Free tier available from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL_ID=gemini-2.5-flash
# GEMINI_TIMEOUT=120

# --- Bedrock (REQUIRED if AI_PROVIDER=bedrock) ---
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# --- Ollama (REQUIRED if AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_ID=llama3
# Seconds to wait for a single Ollama response (local CPU inference is slow)
# OLLAMA_TIMEOUT=300
# Context window in tokens — must fit the rubric prompt or it truncates silently
# OLLAMA_NUM_CTX=4096

# ---------------------------------------------------------------------------
# AWS / S3
# ---------------------------------------------------------------------------
# REQUIRED for Bedrock. For Ollama/Gemini, only required if S3_BUCKET_NAME is
# set (i.e. you want to grade uploaded file attachments). Leave S3_BUCKET_NAME
# empty to skip AWS entirely; answers with file uploads are then flagged
# per-answer instead of crashing the service.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1

# S3 bucket that stores uploaded answer files (optional for Ollama-only)
S3_BUCKET_NAME=your-grader-upload-bucket
S3_UPLOAD_PREFIX=grader-uploads
S3_PRESIGNED_URL_EXPIRES_IN=3600

# Point at an S3-compatible server for local dev (MinIO, LocalStack).
# Leave empty to use real AWS S3.
#   MinIO:      http://localhost:9000
#   LocalStack: http://localhost:4566
# When set, also set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY to the local
# server's credentials (e.g. minioadmin / minioadmin for MinIO).
# AWS_S3_ENDPOINT_URL=http://localhost:9000

# ---------------------------------------------------------------------------
# Grading configuration (OPTIONAL — defaults shown)
# ---------------------------------------------------------------------------

# Maximum tokens per Bedrock invocation
# BEDROCK_MAX_TOKENS=2048
# Seconds between Bedrock requests (helps avoid throttling)
# BEDROCK_REQUEST_DELAY=3

# Number of attempts graded in parallel during batch grading
# GRADING_CONCURRENCY=1

